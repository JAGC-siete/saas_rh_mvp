# 🔐 STAGING ENVIRONMENT VARIABLES CONFIGURATION
# Copy this file to .env.staging for local staging testing
# For Railway deployment, use: ./scripts/setup-railway-staging.sh
# NEVER commit .env.staging to Git (it's already in .gitignore)

# ======================================
# 🚀 DEPLOYMENT ENVIRONMENT
# ======================================
# IMPORTANT: Set to production for staging (Next.js requirement)
NODE_ENV=production
RAILWAY_ENVIRONMENT=staging

# ======================================
# 🌐 SUPABASE CONFIGURATION (STAGING)
# ======================================
# ⚠️ RECOMMENDED: Use a SEPARATE Supabase project for staging
# Get these from your STAGING Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_staging_supabase_service_role_key_here

# ======================================
# 🗄️ DATABASE CONFIGURATION (STAGING)
# ======================================
# ⚠️ RECOMMENDED: Use a SEPARATE database for staging
# Staging Supabase connection string
DATABASE_URL=postgresql://postgres:password@host:port/database_staging

# ======================================
# 🔒 SECURITY & AUTHENTICATION (STAGING)
# ======================================
# ⚠️ CRITICAL: Use DIFFERENT secrets from production!
# Generate these with: openssl rand -base64 32
JWT_SECRET=your_staging_jwt_secret_here_DIFFERENT_FROM_PRODUCTION
SUPABASE_JWT_SECRET=your_staging_supabase_jwt_secret_here
SESSION_SECRET=your_staging_session_secret_here_DIFFERENT_FROM_PRODUCTION

# Rate limiting / logs: RAILWAY_ENVIRONMENT (above) enables trusting X-Forwarded-For (rightmost hop = client on Railway).
# For local API tests without Railway, use TRUST_PROXY=0 so only the TCP peer IP is used.
# Optional: XFF_CLIENT_POSITION=first if your reverse proxy replaces the entire XFF chain.

# ======================================
# 🔗 SITE & DOMAIN CONFIGURATION (STAGING)
# ======================================
# Staging domain (different from production)
NEXT_PUBLIC_SITE_URL=https://staging-humanosisu.net
# Or use Railway domain:
# NEXT_PUBLIC_SITE_URL=https://your-app-staging.railway.app
RAILWAY_PUBLIC_DOMAIN=https://your-app-staging.railway.app

# ======================================
# 🔐 OAUTH PROVIDERS (STAGING)
# ======================================
# Facebook OAuth - Use staging/test app
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=your-staging-facebook-app-id
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=your-staging-facebook-secret

# ======================================
# 📱 SMS AUTHENTICATION (STAGING)
# ======================================
# Twilio SMS - Can use same account but different service
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=your-twilio-message-service-sid-here

# ======================================
# 💳 PAYMENT CONFIGURATION (STAGING)
# ======================================
# ⚠️ ALWAYS use SANDBOX mode for staging!
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_sandbox_webhook_id

# ======================================
# 🎯 TRIAL CONFIGURATION
# ======================================
# Same as production (or adjust for testing)
TRIAL_DURATION_DAYS=7
TRIAL_COOLDOWN_DAYS=30

# ======================================
# ⏰ TIMEZONE & LOCALE
# ======================================
TZ=America/Tegucigalpa
DEFAULT_TIMEZONE=America/Tegucigalpa
DEFAULT_CURRENCY=HNL

# ======================================
# 🌍 APPLICATION CONFIGURATION
# ======================================
NEXT_TELEMETRY_DISABLED=1
SKIP_ENV_VALIDATION=false
BASES_DE_DATOS_URL=https://staging-humanosisu.net

# ======================================
# 🖥️ SERVER CONFIGURATION
# ======================================
PORT=8080
HOSTNAME=0.0.0.0

# ======================================
# ⏰ CRON JOBS SECURITY
# ======================================
# Generate a unique secret for staging cron jobs
CRON_SECRET=your-staging-cron-secret-different-from-production

# ======================================
# 📧 EMAIL SERVICES
# ======================================
# Resend API - Can use same key or separate for staging
RESEND_API_KEY=your-resend-api-key-here

# ======================================
# 🔐 EMPLOYEE SECURITY (STAGING)
# ======================================
# Different peppers from production
EMPLOYEE_LAST5_PEPPER=your_staging_employee_last5_pepper
EMPLOYEE_PIN_PEPPER=your_staging_employee_pin_pepper

# ======================================
# 📝 QUICK SETUP INSTRUCTIONS
# ======================================
#
# 1. LOCAL STAGING TESTING:
#    cp env.staging.example .env.staging
#    Edit .env.staging with your staging values
#    npm run dev  # Will use .env.staging if NODE_ENV=staging
#
# 2. RAILWAY STAGING DEPLOYMENT:
#    ./scripts/setup-railway-staging.sh
#    # Follow the interactive prompts
#
# 3. VERIFY STAGING CONFIGURATION:
#    ./scripts/check-staging-env.sh
#
# 4. DEPLOY TO STAGING:
#    railway environment use staging
#    railway up
#
# ======================================
# ⚠️ STAGING BEST PRACTICES
# ======================================
#
# ✅ Use SEPARATE Supabase project for staging
# ✅ Use SEPARATE database for staging
# ✅ Use DIFFERENT secrets from production
# ✅ Use PayPal SANDBOX mode
# ✅ Use different domain/subdomain
# ✅ Test all features before production
# ✅ Monitor staging logs regularly
# ✅ Never use production data in staging
#
# ======================================
# 🔐 SECURITY CHECKLIST
# ======================================
#
# ✅ .env.staging is in .gitignore
# ✅ All secrets are different from production
# ✅ Staging database is separate
# ✅ PayPal is in sandbox mode
# ✅ No production data in staging
# ✅ Staging domain is different
# ✅ Secrets are stored securely in Railway















