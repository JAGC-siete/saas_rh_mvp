# Docker ignore file - prevents large files from being copied to Docker context
# This works in conjunction with .railwayignore

# Git
.git
.gitignore
.gitattributes

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build outputs
.next
out
dist
build
.turbo
.cache

# Environment files (except example)
.env*
!.env.example

# Logs
*.log
logs

# Coverage
coverage
.nyc_output

# TypeScript
*.tsbuildinfo

# Cache directories
.cache
.parcel-cache
.eslintcache

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Archives
*.zip
*.tar.gz

# Media files
uploads/
public/media/
public/images/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Documentation
docs/_build/
README.md
*.md
!README.md

# Large documentation files that slow down builds
TRIAL_LIMITS_ANALYSIS.md
REALTIME_ATTENDANCE_IMPLEMENTATION_CHECKLIST.md
REALTIME_ATTENDANCE_INDEX.md
RESUMEN_EJECUTIVO_REALTIME_ASISTENCIA.md
RISK_ASSESSMENT_REALTIME_ATTENDANCE.md
SAFE_IMPLEMENTATION_GUIDE.md
SUPABASE_REALTIME_ATTENDANCE_EVALUATION.md

# Test files
tests/
*.test.ts
*.test.tsx
*.test.js
*.spec.ts
*.spec.tsx

# Migration files (not needed at runtime)
supabase/migrations/

# Scripts not needed in production
scripts/