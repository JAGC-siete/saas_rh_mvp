# Supabase (client)
NEXT_PUBLIC_SUPABASE_URL=your_value_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_value_here

# Supabase (server-only)
SUPABASE_SERVICE_ROLE_KEY=your_value_here

# Supabase DB
SUPABASE_DB_URL=your_value_here

# Otros
NODE_ENV=your_value_here
PORT=your_value_here

# Redis Configuration (if using external Redis)
REDIS_URL=your_value_here

# Application settings
APP_NAME=your_value_here
APP_VERSION=your_value_here

# Email settings (for production)
# SMTP_HOST=your_value_here
# SMTP_PORT=your_value_here
# SMTP_USER=your_value_here
# SMTP_PASS=your_value_here

# Honduras specific settings
TIMEZONE=your_value_here
LOCALE=your_value_here

# Payroll statutory JSON (SLV/GTM): default strict validation. Optional staging: STATUTORY_VALIDATE_MODE=warn
# STATUTORY_VALIDATE_STRICT=1 forces fail on invalid JSON even if MODE=warn
# STATUTORY_VALIDATE_MODE=warn

# Security
SESSION_SECRET=your_value_here
ENCRYPTION_KEY=your_value_here
CRON_SECRET=your_value_here

# Habilita /api/env-check, /api/railway-env-check, /debug-env, /railway-debug y /api/employees/debug-attendance.
# En producción debe estar ausente o false salvo diagnóstico temporal.
# ENABLE_SERVER_DIAGNOSTICS=true

# Resend Configuration
RESEND_API_KEY=your_resend_api_key_here
# Transaccional: nómina, vouchers, OTP portal empleados
RESEND_FROM_NOREPLY=SISU Nómina <noreply@humanosisu.net>
# Comercial / contacto humano: cotizaciones, activación, marketing
RESEND_FROM_CONTACT=SISU <jorgearturo@humanosisu.net>
# Legacy (opcional): si solo defines RESEND_FROM, se usa como remitente de contacto
# RESEND_FROM=SISU <jorgearturo@humanosisu.net>

# Cuentas bancarias en cotización (PDF + correo). Al menos una cuenta es obligatoria para mostrar el bloque.
VENTAS_BANK_CLIENT_NAME=JORGE ARTURO GOMEZ COELLO
VENTAS_BANK_CLIENT_DNI=0510199100731
VENTAS_BANK_BAC_ACCOUNT=722983451
# VENTAS_BANK_BANPAIS_ACCOUNT=
# VENTAS_BANK_ATLANTIDA_ACCOUNT=

# Nombre del asesor comercial en mensajes de WhatsApp (opcional, default Jorge)
# NEXT_PUBLIC_VENTAS_SUPPORT_FIRST_NAME=Jorge
# VENTAS_SUPPORT_FIRST_NAME=Jorge

# --- Meta Conversions API (eventos de servidor) ---
# Pixel ID y token generados en Meta Events Manager → Configuración → API de conversiones.
# Mismo ID que en Meta Events Manager (píxel del navegador + CAPI).
# En Railway/Docker basta META_PIXEL_ID en runtime; NEXT_PUBLIC_* también sirve.
# META_PIXEL_ID=833142547420951
# META_CAPI_ACCESS_TOKEN=   # Token de Events Manager → API de conversiones (CAPI)

# --- Google Ads / gtag (conversiones sitio web) ---
# Valor completo send_to que copiás de Google Ads → Conversiones → Etiqueta (p. ej. AW-123456789/xxxxxx).
# Si una variable está vacía, no se dispara esa conversión (solo eventos de engagement en gtag).
# NEXT_PUBLIC_GADS_SEND_TO_ACTIVATION=
# NEXT_PUBLIC_GADS_SEND_TO_CTA=
# NEXT_PUBLIC_GADS_SEND_TO_WHATSAPP=
# NEXT_PUBLIC_GADS_SEND_TO_COMPARISON=
