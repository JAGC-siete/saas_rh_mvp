# 🔐 ENVIRONMENT VARIABLES CONFIGURATION
# Copy this file to .env and fill in your values
# NEVER commit .env to Git (it's already in .gitignore)

# ======================================
# 🚀 DEPLOYMENT ENVIRONMENT
# ======================================
# Set this to: development, staging, production
NODE_ENV=development

# ======================================
# 🌐 SUPABASE CONFIGURATION
# ======================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ======================================
# 🗄️ DATABASE CONFIGURATION
# ======================================
# Supabase connection string
DATABASE_URL=postgresql://postgres:[password]@[host]:[port]/[database]

# ======================================
# 🔒 SECURITY & AUTHENTICATION
# ======================================
# Generate these with: openssl rand -base64 32
JWT_SECRET=your-32-character-jwt-secret-here
SUPABASE_JWT_SECRET=your-32-character-jwt-secret-here
SESSION_SECRET=your-32-character-session-secret-here

# ======================================
# 🔐 OAUTH PROVIDERS
# ======================================
# Facebook OAuth (from Facebook Developer Console)
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=your-facebook-app-id-here
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=your-facebook-app-secret-here

# ======================================
# 📱 SMS AUTHENTICATION
# ======================================
# Twilio SMS (from Twilio Console)
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=your-twilio-message-service-sid-here

# ======================================
# ⏰ TIMEZONE & LOCALE
# ======================================
TZ=America/Tegucigalpa
DEFAULT_TIMEZONE=America/Tegucigalpa
DEFAULT_CURRENCY=HNL

# ======================================
# 🌍 APPLICATION CONFIGURATION
# ======================================
NEXT_TELEMETRY_DISABLED=1
SKIP_ENV_VALIDATION=false
BASES_DE_DATOS_URL=https://your-domain.com

# ======================================
# 🖥️ SERVER CONFIGURATION
# ======================================
PORT=3000
HOSTNAME=localhost

# ======================================
# 🔗 SITE & DOMAIN CONFIGURATION
# ======================================
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
RAILWAY_PUBLIC_DOMAIN=https://your-app.railway.app

# ======================================
# ⏰ CRON JOBS SECURITY
# ======================================
# Generate a unique secret for cron job authentication
CRON_SECRET=your-unique-cron-secret-here

# ======================================
# 📝 INSTRUCTIONS
# ======================================

# 1. DEVELOPMENT SETUP:
#    cp env.example .env
#    Edit .env with your local values
#
# 2. PRODUCTION (Railway):
#    All variables are set in Railway dashboard
#    No .env file needed
#
# 3. CI/CD (GitHub):
#    All variables are set as GitHub Secrets
#    No .env file needed
#
# 4. SECURITY CHECKLIST:
#    ✅ .env is in .gitignore
#    ✅ No hardcoded secrets in code
#    ✅ All sensitive values use environment variables
#    ✅ Fallback values are safe (localhost, example.com)
#
# 5. BEST PRACTICES:
#    - Use descriptive variable names
#    - Group related variables together
#    - Document what each variable does
#    - Use safe fallback values for development
#    - Never commit real secrets to Git
